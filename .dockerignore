# Ignore node_modules (we install dependencies inside Docker)
node_modules/
npm-debug.log
yarn-debug.log
yarn-error.log
pnpm-debug.log

# Ignore build output (Next.js and React build folders)
.next/
build/
dist/

# Ignore local environment variables
.env
.env.local
.env.development
.env.production
.env.test

# Ignore dependency lock files (optional, depends on build strategy)
package-lock.json
yarn.lock
pnpm-lock.yaml

# Ignore logs
logs/
*.log

# Ignore Docker files themselves
Dockerfile
.dockerignore

# Ignore version control files
.git/
.gitignore
.gitlab-ci.yml
.github/

# Ignore Editor/IDE specific files
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Ignore tests and coverage reports
__tests__/
__mocks__/
coverage/
jest.config.js
cypress/
cypress.json

# Ignore cache files
.cache/
.npm/
.yarn/

# Ignore TypeScript-related files (if using TypeScript)
tsconfig.json
tsconfig.tsbuildinfo

# Ignore static export folder (if using Next.js export)
out/
